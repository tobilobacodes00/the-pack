# Normalize line endings across the team (mixed OS). Text is LF in the repo.
* text=auto eol=lf

# Windows-native scripts keep CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binaries — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
