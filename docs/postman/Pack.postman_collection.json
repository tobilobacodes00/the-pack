{
  "info": {
    "name": "Pack Engine",
    "description": "Auto-generated from the FastAPI OpenAPI spec \u2014 do not hand-edit.\n\nRe-generate after adding routes:  `python -m scripts.gen_postman`\n\nSet the `baseUrl` collection variable to `http://localhost:8000` (default).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "documents",
      "item": [
        {
          "name": "List Documents  [GET]",
          "request": {
