                "receipts"
              ]
            },
            "description": "The Receipts \u2014 per-claim provenance for this hunt's delivered brief: every claim's sources\n(who found each, was the page actually read), the Sentinel's challenges and outcomes, the\nclaims that were dropped in verification, and your-documents coverage. 404 until a brief\nexists."
          }
        },
        {
          "name": "Refine Hunt  [POST]",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/hunts/{hunt_id}/refine",
              "host": [
                "{{baseUrl}}"
              ],
