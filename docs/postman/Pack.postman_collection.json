            },
            "description": "Re-draft + re-forge the brief from its existing claims/sources (no re-scout). The new files\nland on the event stream; the Reward refreshes. 404 if no brief, 400 if it had no sources.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instruction\": \"<how_to_re_angle_tighten_the_br>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "header": [
