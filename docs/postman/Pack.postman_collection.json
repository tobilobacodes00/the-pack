    {
      "name": "hunts",
      "item": [
        {
          "name": "Create Hunt  [POST]",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/hunts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hunts"
              ]
            },
            "description": "Open a hunt. Returns 202 with the new hunt_id; the Supervisor starts planning at once.\n\nWatch `hunt_created` \u2192 `plan_proposed` arrive on the stream, then POST `/plan/approve`.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"<value>\",\n  \"instinct_id\": \"<value>\",\n  \"source\": \"typed\",\n  \"strategy\": \"orchestrate\",\n  \"team\": [\n    {}\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "List Hunts  [GET]",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/hunts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hunts"
              ],
              "query": [
                {
                  "key": "project_id",
                  "value": "",
                  "description": "",
                  "disabled": true
                },
                {
                  "key": "cursor",
                  "value": "",
                  "description": "",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "",
                  "description": "",
                  "disabled": true
                }
              ]
            },
            "description": "Recent hunts, newest first \u2014 the Den's Past Hunts list. Optionally scoped to a project.\nCursor pagination: pass the returned `next_cursor` to page older (null when no more)."
          }
        },
        {
          "name": "Clear Hunts  [DELETE]",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/hunts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hunts"
              ]
            },
            "description": "Clear all hunt history (Settings \u2192 Clear hunt history). Leaves documents/memory/instincts."
          }
        },
        {
          "name": "Intake  [POST]",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/hunts/intake",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hunts",
                "intake"
              ]
            },
            "description": "Front-door gate, now state-aware: Alpha is ONE continuous lead. If the conversation already has\na running or delivered hunt (body.hunt_id), the injected [HUNT STATE] header stops it re-asking\nscoping questions or relaunching \u2014 it converses about the live/finished hunt instead. Only a fresh,\nhunt-less turn can signal ready. No hunt is created here \u2014 the frontend creates one on ready=true.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {}\n  ],\n  \"hunt_id\": \"<value>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "Intake Stream  [POST]",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/hunts/intake/stream",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hunts",
                "intake",
                "stream"
              ]
            },
            "description": "SSE variant of /intake \u2014 yields `token` events as text arrives, then a `done` event.\nState-aware like /intake: an in-flight hunt for this thread suppresses relaunch.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    {}\n  ],\n  \"hunt_id\": \"<value>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "Get Hunt  [GET]",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/hunts/{hunt_id}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hunts",
                ":hunt_id"
              ]
            },
            "description": "Snapshot: state plus last_seq (for reconnect/replay). 404 if the hunt is unknown."
          }
        },
        {
          "name": "Patch Hunt  [PATCH]",
