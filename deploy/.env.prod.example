# =============================================================================
# Pack — production environment template.
# On the server: cp deploy/.env.prod.example deploy/.env.prod  then fill in real values.
# .env.prod is gitignored — NEVER commit it.
# =============================================================================

# --- Qwen / DashScope (Alibaba Cloud Model Studio) ---
# Console: https://dashscope-intl.aliyuncs.com — Singapore region (ap-southeast-1)
# International endpoint only (NOT the China one ending in .aliyuncs.com without -intl)
QWEN_API_KEY=sk-replace-me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REGION=ap-southeast-1

# Exact model names — verify in the Model Studio console before launch
# plus is pinned to a dated snapshot (not the floating alias) — verified on a real key to reliably
# accept enable_thinking + prompt-JSON together; the intl region only exposes floating aliases for
# max/flash, so those stay unpinned. Re-verify this snapshot is still live in Model Studio before launch.
QWEN_MODEL_MAX=qwen-max
QWEN_MODEL_PLUS=qwen-plus-2025-12-01
QWEN_MODEL_FLASH=qwen-flash

# --- Web search ---
# DuckDuckGo only — free, keyless, no config needed. Deep page reads use Jina's free tier + a direct
# fetch fallback, also both keyless. There is no other search vendor wired into the app.

# --- Database + cache (EXTERNAL free-tier services — nothing runs on this box) ---
# Postgres lives on Neon (neon.tech) and Redis on Upstash (upstash.com). The ECS box runs only the
# engine + gateway + web — see docker-compose.prod.yml. Both connections MUST use TLS (these are public
# managed hosts); the settings below make that happen. Full signup steps: deploy/ECS_DEPLOY_GUIDE.md.
#
# POSTGRES_URL — copy Neon's "connection string" from its dashboard. Format:
#   postgresql://<user>:<password>@ep-xxxx-xxxx.<region>.aws.neon.tech/<db>
# Do NOT paste Neon's own "?sslmode=require&channel_binding=require" query string — asyncpg does not
# understand libpq query params. Strip everything from the "?" onward and set POSTGRES_SSLMODE below
# instead; that is the knob the engine actually reads (backend/app/db/pool.py).
POSTGRES_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb
# require = verify the server presents a cert but don't pin a local CA file. Neon mandates TLS, so this
# must stay set — an empty value here means a plaintext connection, which Neon refuses.
POSTGRES_SSLMODE=require
#
# REDIS_URL — copy Upstash's connection string. It MUST start with rediss:// (two s's = TLS). The
# gateway's Redis client is built with TLS support specifically so this works; a plain redis:// URL to
# Upstash will be refused at the handshake.
#   rediss://default:<password>@<name>.upstash.io:6379
REDIS_URL=rediss://default:password@your-db.upstash.io:6379

# --- App ---
# Generate SESSION_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-me-with-64-hex-chars
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
GATEWAY_PORT=8080

# --- Access control ---
# Browser traffic is gated by nginx Basic auth over TLS (see DEPLOY.md) — do NOT skip that before
# exposing the box. These are the app-level defenses:
#  * RATE_LIMIT_PER_MIN: per-IP cap on expensive POSTs (/hunts, /parse, /transcribe, /documents).
#  * CORS_ORIGINS: lock to your real origin(s); the "*" default is for local-only.
#  * API_AUTH_TOKEN: shared bearer token gating the engine directly (defense in depth). Generate with
#    python -c "import secrets; print(secrets.token_hex(32))". nginx injects it for /api and /ws.
#  * STRICT_SECRETS: with this on, the engine REFUSES to boot if the secrets above are left default —
#    an unconfigured box can't silently go live.
RATE_LIMIT_PER_MIN=30
CORS_ORIGINS=https://yourdomain.com
API_AUTH_TOKEN=replace-me-with-64-hex-chars
STRICT_SECRETS=true

# --- Spend / boundary ---
FIRST_HUNT_CAP_USD=0.50
STEP_TIMEOUT_S=120.0

# --- Qwen pricing (USD per 1M tokens) ---
# CRITICAL: the Boundary (the dollar spend cap) is only as correct as these rates. Numbers that are
# too low make the cap halt far too late and blow the budget. VERIFY the real per-1M rates in Model
# Studio for your tier/region and set them here. The values below are realistic ballparks for the
# intl (Singapore) endpoint — confirm before launch.
PRICE_MAX_IN_PER_M=1.60
PRICE_MAX_OUT_PER_M=6.40
PRICE_PLUS_IN_PER_M=0.40
PRICE_PLUS_OUT_PER_M=1.20
PRICE_FLASH_IN_PER_M=0.10
PRICE_FLASH_OUT_PER_M=0.40

# --- Resilience ---
QWEN_MAX_RETRIES=3
QWEN_BACKOFF_BASE_S=0.5
QWEN_BREAKER_THRESHOLD=5
QWEN_BREAKER_COOLDOWN_S=30.0

# --- Alibaba Cloud OSS (Object Storage Service) — the forged-artifact store ---
# When these four are set, the engine offloads forged files (PDF/DOCX/PPTX/PNG/…) to your OSS bucket
# instead of inlining them as base64 in Postgres; downloads stream the bytes back from OSS. Leave them
# ALL empty and the engine falls back to local disk (OSS_LOCAL_DIR) — the app still runs, just without
# the object store. Code path: backend/app/storage/oss.py.
# Create a bucket in the OSS console (same region as the ECS box — ap-southeast-1) and a RAM user with
# AliyunOSSFullAccess; use its AccessKey pair below. Endpoint is the region's, e.g.
# https://oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET=pack-artifacts
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
OSS_ACCESS_KEY_ID=replace-me
OSS_ACCESS_KEY_SECRET=replace-me
OSS_PREFIX=artifacts/
