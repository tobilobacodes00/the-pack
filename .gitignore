# Root — repo-level only. Each service owns its own .gitignore:
#   backend/.gitignore · frontend/.gitignore · gateway/.gitignore

# --- Secrets (NEVER commit), repo-wide safety net ---
.env
.env.*
!.env.example
*.pem
*.key
.htpasswd
secrets/

# --- Local reference material (harvest, never commit) ---
reference/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# --- Logs ---
*.log

# --- Diagram render scratch (intermediate screenshots/crops; only the final PNGs are kept) ---
docs/diagram-src/raw_*.png
docs/diagram-src/preview_*.png
