# =============================================================================
# Pack — environment template. Copy to .env and fill in real values.
# Real secrets are NEVER committed (.env is gitignored). Keys are server-side only.
# =============================================================================

# --- Qwen / Alibaba Cloud Model Studio (DashScope) ---
# The engine points the OpenAI SDK at Qwen's OpenAI-compatible endpoint.
# Region nearest Nigeria with Model Studio availability — verify in the console (D6).
# Singapore is the likely answer (Doc 04 §04, §07).
QWEN_API_KEY=sk-replace-me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REGION=ap-southeast-1

# Model-tier registry — verify the REAL model names in Model Studio on day 1 (F14).
# These are placeholders kept in config, never hard-coded (Doc 04 §04).
QWEN_MODEL_MAX=qwen-max
QWEN_MODEL_PLUS=qwen-plus
QWEN_MODEL_FLASH=qwen-flash

# --- Qwen voice model (transcription) — access checked now, contract freezes Jun 16 ---
# Fallback is Qwen ASR behind the same Transcriber interface (decision Jun 20, D7).
QWEN_VOICE_API_KEY=
QWEN_VOICE_BASE_URL=

# --- Research providers (multi-source) — the retrieval behind the Scout's web_search/web_fetch ---
# Every provider whose key is set joins the fan-out; keyless ones (Hacker News, Wikidata, DBpedia,
# OpenAlex) always run. If NO key below is set => deterministic canned provider, engine runs offline.
# NOTE: free tiers are small (NewsData 30/day, SerpAPI 100/mo, GNews 100/day) — many providers ×
# scouts × queries burns them fast; cap which providers/categories run per hunt if you hit limits.
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=          # Tavily (primary web search): https://tavily.com
SEARCH_MAX_RESULTS=8
# web search
EXA_API_KEY=             # https://exa.ai
SERPAPI_API_KEY=         # https://serpapi.com
YOUCOM_API_KEY=          # https://you.com/platform
# news
NEWSAPI_KEY=             # https://newsapi.org
GNEWS_API_KEY=           # https://gnews.io
NEWSDATA_API_KEY=        # https://newsdata.io
# crawling / deep readers (used for web_fetch, in this priority order)
JINA_API_KEY=            # https://jina.ai/reader
FIRECRAWL_API_KEY=       # https://firecrawl.dev
APIFY_API_KEY=           # https://apify.com (best-effort; slow actor runs)
# academic
CORE_API_KEY=            # https://core.ac.uk
OPENALEX_MAILTO=         # your email — OpenAlex is keyless but wants a contact for the polite pool
# community / knowledge graph
GITHUB_TOKEN=            # https://github.com/settings/tokens (repo search)
GOOGLE_KG_API_KEY=       # Google Knowledge Graph Search API

# --- Research strategy (the selectable engine modes). Orthogonal to the autonomy mode. ---
# orchestrate (dynamic, default) | deep_dive (iterative) | critique (plan-execute-critique).
DEFAULT_STRATEGY=orchestrate

# --- Redis (Tair on Alibaba Cloud) — the event-stream seam between engine & gateway ---
REDIS_URL=redis://localhost:6379/0

# --- Postgres (ApsaraDB RDS) — durable event archive + data model ---
POSTGRES_URL=postgresql://pack:pack@localhost:5432/pack
# TLS: empty for local Docker; "require" (encrypt) or "verify-full" (with CA) for cloud RDS.
POSTGRES_SSLMODE=

# --- OSS bucket (artifacts, uploads) — objects private, signed URLs only ---
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# --- App ---
# Anonymous browser sessions only — no login in the hackathon build (D5).
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
# CORS — comma-separated allowed origins; "*" allows all (fine for local dev, lock down in prod).
CORS_ORIGINS=*
# Per-IP rate limit on POST /hunts|/parse|/transcribe|/documents (0 = off).
RATE_LIMIT_PER_MIN=30

# First-hunt silent spend cap, USD (Doc 04 §04 / F7).
FIRST_HUNT_CAP_USD=0.50
